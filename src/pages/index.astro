---
import '../styles/global.css';

const gleamExample = `import spillway

let state = spillway.new_sequence_state()
let joined = spillway.client_join(state, "client-7", 0)

case spillway.assign_sequence_number(joined, "client-7", 1, 0) {
  Ok(result) -> result
  Error(reason) -> reason
}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Spillway is a type-safe Gleam library for Fluid Framework protocol logic: sequencing, sessions, signals, summaries, nacks, and JWT validation.">
    <title>Spillway · Typed Fluid protocol flow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Saira+Condensed:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
  </head>
  <body>
    <header class="masthead" aria-label="Site header">
      <a class="brand" href="/" aria-label="Spillway home">
        <img src="/icon.svg" alt="" width="38" height="38">
        <span>spillway</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="#boundary">Boundary</a>
        <a href="#flow">Flow</a>
        <a href="#api">API</a>
        <a href="#install">Install</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__copy">
          <p class="signal">Gleam protocol logic for collaborative systems</p>
          <h1 id="hero-title">Control Fluid protocol state at the typed boundary.</h1>
          <p class="hero__lede">Spillway extracts the typed core of Fluid Framework sessions: sequencing, message validation, nacks, signals, summaries, and scoped JWT checks for BEAM systems that need predictable collaborative flow.</p>
          <div class="hero__actions" aria-label="Primary actions">
            <a class="button" href="#install">Start with Gleam</a>
            <a class="text-link" href="#api">Read the API shape</a>
            <a class="text-link" href="https://github.com/tylerbutler/spillway/tree/main/test">See examples</a>
          </div>
        </div>

        <div class="control-panel" aria-label="Protocol control diagram">
          <div class="gauge">
            <span class="gauge__label">current_sn</span>
            <span class="gauge__value">monotonic</span>
          </div>
          <div class="channel" aria-label="Protocol state channels">
            <span><b>join</b><small>scope + tenant</small></span>
            <span><b>op</b><small>csn -> sn</small></span>
            <span><b>signal</b><small>ack / nack</small></span>
          </div>
          <ol class="locks">
            <li><span>connect</span><strong>validate claims</strong></li>
            <li><span>submit op</span><strong>assign sequence</strong></li>
            <li><span>summarize</span><strong>track minimum sequence</strong></li>
          </ol>
        </div>
      </section>

      <section class="boundary-section" id="boundary" aria-labelledby="boundary-title">
        <div>
          <p class="section-label">Stack boundary</p>
          <h2 id="boundary-title">Small enough to own one layer.</h2>
        </div>
        <ol class="boundary-chain" aria-label="Where Spillway sits in the Fluid stack">
          <li>
            <span>Above</span>
            <strong>Transport + persistence</strong>
            <p>Your server keeps sockets, storage, auth issuance, and document lifetime.</p>
          </li>
          <li aria-current="step">
            <span>Here</span>
            <strong>Spillway protocol core</strong>
            <p>Typed sequencing, session checks, nacks, signals, summaries, and JWT claim validation.</p>
          </li>
          <li>
            <span>Below</span>
            <strong>Fluid clients</strong>
            <p>Clients receive ordered protocol responses without depending on a full server stack.</p>
          </li>
        </ol>
      </section>

      <section class="flow-section" id="flow" aria-labelledby="flow-title">
        <div>
          <p class="section-label">Protocol flow</p>
          <h2 id="flow-title">A narrow layer with firm gates.</h2>
        </div>
        <div class="flow-grid">
          <article>
            <h3>Session admission</h3>
            <p>Validate tenant, document, expiration, and scope before a client enters the collaborative channel.</p>
          </article>
          <article>
            <h3>Ordered operations</h3>
            <p>Track connected clients, client sequence numbers, reference sequence numbers, and minimum sequence progression.</p>
          </article>
          <article>
            <h3>Protocol responses</h3>
            <p>Build nacks, summaries, acks, and signals with typed constructors instead of ad-hoc JSON shapes.</p>
          </article>
        </div>
      </section>

      <section class="api-section" id="api" aria-labelledby="api-title">
        <div class="api-section__copy">
          <p class="section-label">Typed edges</p>
          <h2 id="api-title">The public API names the state changes.</h2>
          <p>Spillway keeps wire-format concerns explicit: clients join, ops receive sequence numbers, claims are checked, and invalid messages become protocol nacks.</p>
          <p class="api-links">
            <a class="text-link" href="https://hexdocs.pm/spillway/">HexDocs package docs</a>
            <a class="text-link" href="https://github.com/tylerbutler/spillway">Browse source</a>
          </p>
        </div>
        <pre class="code-well" aria-label="Gleam example"><code>{gleamExample}</code></pre>
      </section>

      <section class="install-section" id="install" aria-labelledby="install-title">
        <div>
          <p class="section-label">Install</p>
          <h2 id="install-title">Add the protocol core, not the server.</h2>
          <p>Spillway is intentionally small: Gleam stdlib plus JSON, ready to sit under a server layer that owns transport, persistence, and deployment policy.</p>
        </div>
        <div class="install-actions">
          <pre class="install-command" aria-label="Install command"><code>gleam add spillway</code></pre>
          <a class="text-link" href="https://hexdocs.pm/spillway/">Check package docs</a>
        </div>
      </section>
    </main>
  </body>
</html>
